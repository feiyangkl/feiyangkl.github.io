</span><span class="line">$ sudo gem install cocoapods
</span><span class="line"># 删除包
</span><span class="line">$ gem uninstall cocoapods
</span><span class="line"># 更新包
</span><span class="line">$ sudo gem update
</span><span class="line"># 列出本地安装的包
</span><span class="line">$ gem list
</span><span class="line"># 更新安装的包
</span><span class="line">$ pod install --no-repo-update</span></code></pre></td></tr></table></div></figure></notextile></div>

